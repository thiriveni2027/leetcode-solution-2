class Solution {
    public int getLucky(String s, int k) {

        int sum = 0;

        for (int i = 0; i < s.length(); i++) {

            int n = s.charAt(i) - 'a' + 1;

            while (n > 0) {
                sum = sum + n % 10;
                n = n / 10;
            }
        }

        for (int i = 1; i < k; i++) {

            int newSum = 0;

            while (sum > 0) {
                newSum = newSum + sum % 10;
                sum = sum / 10;
            }

            sum = newSum;
        }

        return sum;
    }
}
